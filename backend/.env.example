# MongoDB connection (never commit real credentials)
MONGODB_URI=mongodb://127.0.0.1:27017/hospital_queue

# HTTP server
PORT=3000

# Rate limiting (tune per deployment)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Optional: comma-separated allowed origins (e.g. http://localhost:3000). If omitted, reflect request origin in dev.
# CORS_ORIGIN=http://localhost:3000
